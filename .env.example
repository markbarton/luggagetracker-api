APP_NAME=luggagetracker-api
CUSTOM_PORT=8765

# Mongo — replace with your connection string
CUSTOM_MONGO_CONNECTION=mongodb://user:pass@host:27017

# JWT — MUST be at least 32 chars in production; generate with: openssl rand -hex 32
CUSTOM_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
CUSTOM_JWT_WEB_ACCESS_TTL=15m
CUSTOM_JWT_WEB_REFRESH_TTL=30d
CUSTOM_JWT_MOBILE_ACCESS_TTL=365d

# bcrypt work factor (4..15)
CUSTOM_BCRYPT_ROUNDS=12

# Web base URL (used inside email links, e.g. https://app.example.com)
CUSTOM_WEB_BASE_URL=http://localhost:3000

# SMTP — external email provider
CUSTOM_SMTP_HOST=smtp.example.com
CUSTOM_SMTP_PORT=587
CUSTOM_SMTP_SECURE=false
CUSTOM_SMTP_USER=
CUSTOM_SMTP_PASS=
CUSTOM_SMTP_FROM="Luggage Tracker <no-reply@example.com>"

# Email token TTLs (supports Ns, Nm, Nh, Nd)
CUSTOM_EMAIL_TOKEN_PASSWORD_RESET_TTL=1h
CUSTOM_EMAIL_TOKEN_EMAIL_VERIFY_TTL=24h
CUSTOM_EMAIL_TOKEN_MAGIC_LINK_TTL=15m
