{
  "name": "api-template",
  "version": "2.0.0",
  "description": "Template for Express with TypeScript",
  "main": "server.js",
  "scripts": {
    "build": "tsc --project .",
    "local": "tsc --project . && cross-env NODE_ENV=local node dist/server",
    "dev": "tsc --project . && cross-env NODE_ENV=development node dist/server",
    "start": "tsc --project . && cross-env NODE_ENV=production node dist/server",
    "node:dev": "cross-env NODE_ENV=development node server",
    "node:start": "cross-env NODE_ENV=production node server",
    "prepare": "husky"
  },
  "author": "Mark Barton",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "body-parser": "^1.20.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "express-list-endpoints": "^6.0.0",
    "express-validation": "^4.1.0",
    "fast-safe-stringify": "^2.1.1",
    "follow-redirects": "^1.15.11",
    "mongodb": "^6.10.0",
    "node-schedule": "^2.1.0",
    "pretty-error": "^4.0.0",
    "winston": "^3.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/express-list-endpoints": "^6.0.0",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^18.19.130",
    "@types/node-schedule": "^2.1.0",
    "husky": "^9.1.7",
    "ts-node": "^10.9.1",
    "typescript": "^4.7.4"
  }
}
